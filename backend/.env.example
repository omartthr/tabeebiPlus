PORT=5000
NODE_ENV=development

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# SMS (Twilio / Netgsm)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment (iyzico / Stripe)
PAYMENT_PROVIDER=iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
STRIPE_SECRET_KEY=

# Redis
REDIS_URL=redis://localhost:6379
